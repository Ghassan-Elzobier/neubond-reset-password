# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Vercel Blob (private store — used for IFU PDF storage)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Email (Resend)
RESEND_API_KEY=re_...
SEND_EMAIL_HOOK_SECRET=v1,whsec_...
SENDER_EMAIL=Neubond <info@example.com>

# IFU: comma-separated list of email addresses authorized to publish new IFU versions.
# Publishing is always restricted to these emails regardless of any other setting.
IFU_PUBLISHER_EMAILS=publisher@example.com,admin@example.com

# IFU pilot read gate.
# Set to "true" to require users to be signed in to VIEW the IFU (for closed pilots).
# Leave unset (or any value other than "true") for public access — this is the required
# state for launch, because the QR code on packaging must reach /ifu/current without login.
# IFU_REQUIRE_AUTH=true
